        metr.pack(fill=tk.X, pady=(0, 20))
        aguardando = len([x for x in DB["fila"] if x["status"] == "Aguardando"])
        card_info(metr, "Consultas hoje",    str(len(DB["consultas"])),      "📅", C["accent2"])
        card_info(metr, "Pacientes cad.",    str(len(DB["pacientes"])),      "👤", C["accent"])
        card_info(metr, "Na fila agora",     str(aguardando),                "🔢", C["orange"])
        card_info(metr, "Confirmadas",       str(len([c for c in DB["consultas"] if c["status"] == "Confirmada"])), "✅", C["success"])

        # Layout 2 colunas
        row2 = tk.Frame(cont, bg=C["bg_deep"])
        row2.pack(fill=tk.BOTH, expand=True)

        # ── Coluna esquerda: próximas consultas do dia ─────────
        card_ag = tk.Frame(row2, bg=C["bg_card"], highlightthickness=1, highlightbackground=C["border"])
        card_ag.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=(0, 12))
        tk.Label(card_ag, text="📅  Agenda de Hoje", font=("Georgia", 13, "bold"), bg=C["bg_card"], fg=C["text_hi"]).pack(anchor="w", padx=18, pady=(14, 6))
        separador(card_ag, pady=0)
        for c in DB["consultas"][:3]:
            cor_s = C["success"] if c["status"] == "Confirmada" else C["warning"]
            row = tk.Frame(card_ag, bg=C["bg_card"])
            row.pack(fill=tk.X, padx=16, pady=7)
            tk.Label(row, text=c["hora"], font=("Courier", 12, "bold"), bg=C["bg_card"], fg=C["accent2"], width=6).pack(side=tk.LEFT)
