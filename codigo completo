        self._at_frames["home"] = f
        u = DB["usuarios"][self._at_login]
        hora = time.localtime().tm_hour
        saud = "Bom dia" if hora < 12 else ("Boa tarde" if hora < 18 else "Boa noite")

        cont = tk.Frame(f, bg=C["bg_deep"])
        cont.pack(fill=tk.BOTH, expand=True, padx=32, pady=24)

