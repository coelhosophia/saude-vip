# ══════════════════════════════════════════════════════════════
#  LOGO (Canvas tk desenhado via código)
#  Recebe: pai=widget pai, bg=cor de fundo, escala=tamanho
#  Retorna: widget Canvas pronto para .pack()
# ══════════════════════════════════════════════════════════════
def desenhar_logo(pai, bg, escala=1.0):
    w, h = int(80 * escala), int(80 * escala)
    c = tk.Canvas(pai, width=w, height=h, bg=bg, highlightthickness=0, bd=0)
    cx, cy, r = w / 2, h / 2, int(34 * escala)
    # Círculo externo
    c.create_oval(cx - r, cy - r, cx + r, cy + r, outline=C["accent"], width=int(3 * escala))
    # Cruz (símbolo de saúde)
    bw, bl = int(8 * escala), int(20 * escala)
    c.create_rectangle(cx - bw // 2, cy - bl, cx + bw // 2, cy + bl, fill=C["accent"], outline="")
    c.create_rectangle(cx - bl, cy - bw // 2, cx + bl, cy + bw // 2, fill=C["accent"], outline="")
    # Ponto central
    pr = int(4 * escala)
    c.create_oval(cx - pr, cy - pr, cx + pr, cy + pr, fill=C["bg_deep"], outline=C["accent"], width=int(2 * escala))
    return c


