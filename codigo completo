def rotulo(pai, texto, bg, top=0):
    """Label pequeno de rótulo acima de um campo de formulário."""
    tk.Label(pai, text=texto, font=("Helvetica", 9, "bold"),
             bg=bg, fg=C["text_lo"], anchor="w").pack(fill=tk.X, pady=(top, 0))


def campo(pai, bg, placeholder="", show=""):
    """
    Campo de entrada com borda destacada ao focar.
    Suporta placeholder (texto cinza que some ao clicar)
    e 'show' para campos de senha (ex: show='●').
    """
    frame = tk.Frame(pai, bg=C["bg_card"], highlightthickness=1, highlightbackground=C["border"])
    frame.pack(fill=tk.X, pady=(4, 0))
    e = tk.Entry(frame, font=("Helvetica", 13), bg=C["bg_card"], fg=C["text_hi"],
                 insertbackground=C["accent"], relief=tk.FLAT, bd=8, show=show)
    e.pack(fill=tk.BOTH, expand=True)
    if placeholder:
        e.insert(0, placeholder)
        e.config(fg=C["text_lo"])
        def fi(ev):
            if e.get() == placeholder:
                e.delete(0, tk.END)
                e.config(fg=C["text_hi"])
            frame.config(highlightbackground=C["accent"])
        def fo(ev):
            if not e.get():
                e.insert(0, placeholder)
                e.config(fg=C["text_lo"])
            frame.config(highlightbackground=C["border"])
        e.bind("<FocusIn>", fi)
        e.bind("<FocusOut>", fo)
    else:
        e.bind("<FocusIn>",  lambda ev: frame.config(highlightbackground=C["accent"]))
        e.bind("<FocusOut>", lambda ev: frame.config(highlightbackground=C["border"]))
    return e


def btn_primario(pai, texto, cmd, bg_cor=None):
    """Botão principal com efeito hover. Cor padrão = accent_dim."""
    bg_c = bg_cor or C["accent_dim"]
    hover = C["accent"] if bg_c == C["accent_dim"] else C["accent2"]
    b = tk.Button(pai, text=texto, font=("Helvetica", 12, "bold"),
                  bg=bg_c, fg=C["white"], activebackground=hover,
                  activeforeground=C["white"], cursor="hand2",
                  relief=tk.FLAT, bd=0, pady=10, command=cmd)
    b.pack(fill=tk.X, pady=(12, 0))
    b.bind("<Enter>", lambda _: b.config(bg=hover))
    b.bind("<Leave>", lambda _: b.config(bg=bg_c))
    return b


def separador(pai, bg=None, pady=12):
    """Linha horizontal fina para dividir seções."""
    tk.Frame(pai, bg=bg or C["border"], height=1).pack(fill=tk.X, pady=pady)


def card_info(pai, titulo, valor, icon, cor_valor=None):
    """
    Card de métrica com ícone, título e valor grande.
    Usado nos dashboards para exibir KPIs.
    """
    card = tk.Frame(pai, bg=C["bg_card"], highlightthickness=1, highlightbackground=C["border"])
    card.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=(0, 8))
    inner = tk.Frame(card, bg=C["bg_card"])
    inner.pack(padx=16, pady=14, fill=tk.X)
    top = tk.Frame(inner, bg=C["bg_card"])
    top.pack(fill=tk.X)
    tk.Label(top, text=icon, font=("Arial", 18), bg=C["bg_card"], fg=cor_valor or C["accent"]).pack(side=tk.LEFT)
    tk.Label(top, text=titulo, font=("Helvetica", 10), bg=C["bg_card"], fg=C["text_mid"]).pack(side=tk.LEFT, padx=8)
    tk.Label(inner, text=valor, font=("Georgia", 28, "bold"), bg=C["bg_card"], fg=C["text_hi"]).pack(anchor="w", pady=(4, 0))
    return card


