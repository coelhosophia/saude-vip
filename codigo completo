            messagebox.showinfo("Sucesso", f"Paciente '{nome}' cadastrado!", parent=win)
            win.destroy()

        b = tk.Button(win, text="  Cadastrar  ", font=("Helvetica", 12, "bold"),
                      bg=C["accent_dim"], fg=C["white"], activebackground=C["accent"],
                      relief=tk.FLAT, bd=0, pady=10, command=salvar)
