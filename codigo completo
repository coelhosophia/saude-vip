class App:
    def __init__(self, root):
        self.root = root
        self.root.title("Sistema da Saúde VIP")
        self.root.configure(bg=C["bg_deep"])
        # F11 alterna tela cheia
        self.root.bind("<F11>", self._toggle_fs)
        self.root.bind("<Escape>", lambda e: self.root.attributes("-fullscreen", False))
        self._mostrar_login()

    def _toggle_fs(self, e=None):
        """Alterna modo tela cheia."""
        self.root.attributes("-fullscreen", not self.root.attributes("-fullscreen"))

    def _limpar(self):
        """Remove todos os widgets da janela (troca de tela)."""
        for w in self.root.winfo_children():
            w.destroy()

    def _centralizar(self, w, h):
        """Centraliza a janela na tela do monitor."""
        self.root.update_idletasks()
        sw = self.root.winfo_screenwidth()
        sh = self.root.winfo_screenheight()
        self.root.geometry(f"+{sw // 2 - w // 2}+{sh // 2 - h // 2}")

