                self._at_construir_pacientes()
                self._at_navegar("pacientes")

        b = tk.Button(form, text="  Cadastrar Paciente  →", font=("Helvetica", 12, "bold"),
                      bg=C["accent2_dim"], fg=C["white"], activebackground=C["accent2"],
                      relief=tk.FLAT, bd=0, pady=10, cursor="hand2", command=salvar)
        b.pack(fill=tk.X, pady=(16, 24))
        b.bind("<Enter>", lambda _: b.config(bg=C["accent2"]))
        b.bind("<Leave>", lambda _: b.config(bg=C["accent2_dim"]))

    # ── Página CONFIGURAÇÕES do atendente ──────────────────────
    def _at_construir_config(self):
        """
        Dados do atendente (setor, turno, contato)
        e toggles de notificações e preferências.
        """
        f = tk.Frame(self._at_container, bg=C["bg_deep"])
        self._at_frames["config"] = f
        cont = tk.Frame(f, bg=C["bg_deep"])
        cont.pack(fill=tk.BOTH, expand=True, padx=40, pady=28)

        tk.Label(cont, text="Configurações", font=("Georgia", 20, "bold"), bg=C["bg_deep"], fg=C["text_hi"]).pack(anchor="w")
        tk.Label(cont, text="Seus dados e preferências de trabalho.", font=("Helvetica", 12), bg=C["bg_deep"], fg=C["text_mid"]).pack(anchor="w", pady=(0, 24))

        u = DB["usuarios"][self._at_login]

        # Card de dados do atendente
        card = tk.Frame(cont, bg=C["bg_card"], highlightthickness=1, highlightbackground=C["border"])
        card.pack(fill=tk.X, pady=(0, 16))
        tk.Label(card, text="Dados do Atendente", font=("Helvetica", 12, "bold"), bg=C["bg_card"], fg=C["text_hi"]).pack(anchor="w", padx=20, pady=(14, 8))
        separador(card, pady=0)
        for campo_k, label_k in [("nome", "Nome"), ("setor", "Setor"), ("turno", "Turno"), ("email", "E-mail"), ("telefone", "Telefone")]:
            row = tk.Frame(card, bg=C["bg_card"])
            row.pack(fill=tk.X, padx=20, pady=8)
            tk.Label(row, text=label_k, font=("Helvetica", 11), bg=C["bg_card"], fg=C["text_mid"], width=16, anchor="w").pack(side=tk.LEFT)
            tk.Label(row, text=u.get(campo_k, "—"), font=("Helvetica", 11, "bold"), bg=C["bg_card"], fg=C["text_hi"]).pack(side=tk.LEFT)
            separador(card, pady=0)
        tk.Frame(card, height=8, bg=C["bg_card"]).pack()

        # Seção de notificações com toggles
        c2 = tk.Frame(cont, bg=C["bg_card"], highlightthickness=1, highlightbackground=C["border"])
        c2.pack(fill=tk.X, pady=(0, 14))
        tk.Label(c2, text="🔔  Notificações", font=("Helvetica", 12, "bold"), bg=C["bg_card"], fg=C["text_hi"]).pack(anchor="w", padx=20, pady=(14, 6))
        separador(c2, pady=0)
        for op, ini in [("Alertas de novos agendamentos", True),
                        ("Avisos de pacientes na fila", True),
                        ("Resumo diário por e-mail", False),
                        ("Som ao chamar próximo da fila", True)]:
            row = tk.Frame(c2, bg=C["bg_card"])
            row.pack(fill=tk.X, padx=20, pady=8)
            tk.Label(row, text=op, font=("Helvetica", 11), bg=C["bg_card"], fg=C["text_mid"]).pack(side=tk.LEFT)
            var = tk.BooleanVar(value=ini)
            lbl = tk.Label(row, text="Ativo" if ini else "Inativo", font=("Helvetica", 10, "bold"),
                           bg=C["bg_card"], fg=C["success"] if ini else C["text_lo"])
            lbl.pack(side=tk.RIGHT, padx=(0, 10))
            def _tog(v=var, l=lbl):
                v.set(not v.get())
                l.config(text="Ativo" if v.get() else "Inativo", fg=C["success"] if v.get() else C["text_lo"])
            tk.Button(row, text="Alternar", font=("Helvetica", 9), bg=C["bg_panel"], fg=C["text_mid"],
                      activebackground=C["border"], relief=tk.FLAT, bd=0, padx=10, pady=3, cursor="hand2", command=_tog).pack(side=tk.RIGHT)
            separador(c2, pady=0)
        tk.Frame(c2, height=6, bg=C["bg_card"]).pack()

        b = tk.Button(cont, text="  💾  Salvar Configurações", font=("Helvetica", 12, "bold"),
                      bg=C["accent2_dim"], fg=C["white"], activebackground=C["accent2"],
                      relief=tk.FLAT, bd=0, padx=20, pady=10, cursor="hand2",
                      command=lambda: messagebox.showinfo("OK", "Configurações salvas! ✅", parent=self.root))
        b.pack(anchor="w", pady=(4, 0))
        b.bind("<Enter>", lambda _: b.config(bg=C["accent2"]))
        b.bind("<Leave>", lambda _: b.config(bg=C["accent2_dim"]))


