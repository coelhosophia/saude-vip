        separador(card, pady=0)
        for campo_k, label_k in [("nome", "Nome"), ("crm", "CRM"), ("especialidade", "Especialidade"),
                                   ("email", "E-mail"), ("telefone", "Telefone")]:
            row = tk.Frame(card, bg=C["bg_card"])
