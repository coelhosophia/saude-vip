                        ("E-mail", "paciente@email.com"), ("Plano de Saúde", "Unimed, Particular…"),
                        ("Tipo Sanguíneo", "A+, O-, AB+…"), ("Alergias", "Nenhuma"),
                        ("Médico Responsável", "Dr./Dra. Nome")]:
            rotulo(form, cam.upper(), C["bg_deep"], top=10)
