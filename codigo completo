    def _at_registrar_chegada(self):
        """
        Popup para registrar chegada de um paciente.
        Gera senha automática incremental (A001, A002…).
        """
        win = tk.Toplevel(self.root)
        win.title("Registrar Chegada")
        win.configure(bg=C["bg_deep"])
        win.geometry("480x440")
        win.resizable(False, False)
        win.grab_set()
        tk.Label(win, text="Registrar Chegada", font=("Georgia", 17, "bold"), bg=C["bg_deep"], fg=C["text_hi"]).pack(pady=16)
        form = tk.Frame(win, bg=C["bg_deep"])
        form.pack(padx=36, fill=tk.X)
        ents = {}
        for cam, ph in [("Nome do Paciente", "Nome completo"),
                        ("Tipo de Atendimento", "Consulta / Retorno / Exame"),
                        ("Médico", "Dr./Dra. Nome")]:
            rotulo(form, cam.upper(), C["bg_deep"], top=12)
            ents[cam] = campo(form, C["bg_deep"], ph)

        def salvar():
            nome = ents["Nome do Paciente"].get().strip()
            if not nome:
                messagebox.showwarning("Atenção", "Nome do paciente é obrigatório.", parent=win)
                return
            # Gera número de senha e incrementa o contador global
            num = _proximo_num_fila[0]
            _proximo_num_fila[0] += 1
            senha = f"A{num:03d}"
            hora_chegada = time.strftime("%H:%M")
            DB["fila"].append({
                "senha":   senha,
                "nome":    nome,
                "tipo":    ents["Tipo de Atendimento"].get().strip() or "Consulta",
                "medico":  ents["Médico"].get().strip() or "—",
                "chegada": hora_chegada,
                "status":  "Aguardando",
            })
            messagebox.showinfo("Chegada Registrada",
                                f"Paciente: {nome}\nSenha: {senha}\nHorário: {hora_chegada}", parent=win)
            win.destroy()
            # Recarrega a página de fila se estiver ativa
            if "fila" in self._at_frames:
                self._at_frames["fila"].destroy()
                del self._at_frames["fila"]
                self._at_construir_fila()
                self._at_navegar("fila")

        b = tk.Button(win, text="  Registrar  →", font=("Helvetica", 12, "bold"),
                      bg=C["accent2_dim"], fg=C["white"], activebackground=C["accent2"],
                      relief=tk.FLAT, bd=0, pady=10, command=salvar)
        b.pack(fill=tk.X, padx=36, pady=16)
        b.bind("<Enter>", lambda _: b.config(bg=C["accent2"]))
        b.bind("<Leave>", lambda _: b.config(bg=C["accent2_dim"]))

    def _at_chamar_proximo(self):
        """
        Chama o próximo da fila:
        - Encontra o primeiro com status 'Aguardando'
        - Muda para 'Em atendimento'
        - Exibe popup com dados da chamada
        - Atualiza a tela de fila
        """
        proximo = next((x for x in DB["fila"] if x["status"] == "Aguardando"), None)
        if not proximo:
            messagebox.showinfo("Fila Vazia", "Não há pacientes aguardando no momento.")
            return
        proximo["status"] = "Em atendimento"
        messagebox.showinfo("Chamando",
                            f"Senha: {proximo['senha']}\n"
                            f"Paciente: {proximo['nome']}\n"
                            f"Tipo: {proximo['tipo']}\n"
                            f"Médico: {proximo['medico']}")
        # Recarrega a página de fila
        if "fila" in self._at_frames:
            self._at_frames["fila"].destroy()
            del self._at_frames["fila"]
            self._at_construir_fila()
            self._at_navegar("fila")

