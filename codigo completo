    def _at_nova_consulta(self):
        """
        Popup para o atendente agendar uma nova consulta.
        Inclui campo de convênio, diferente da versão do médico.
        """
        win = tk.Toplevel(self.root)
        win.title("Agendar Consulta")
        win.configure(bg=C["bg_deep"])
        win.geometry("480x520")
        win.resizable(False, False)
        win.grab_set()
        tk.Label(win, text="Nova Consulta", font=("Georgia", 17, "bold"), bg=C["bg_deep"], fg=C["text_hi"]).pack(pady=16)
        form = tk.Frame(win, bg=C["bg_deep"])
        form.pack(padx=36, fill=tk.X)
        ents = {}
        for cam, ph in [("Paciente", "Nome completo do paciente"),
                        ("Médico", "Dr./Dra. Nome"), ("Data", "DD/MM/AAAA"),
                        ("Hora", "HH:MM"), ("Tipo", "Consulta / Retorno / Exame"),
                        ("Convênio", "Unimed, Particular…")]:
            rotulo(form, cam.upper(), C["bg_deep"], top=10)
            ents[cam] = campo(form, C["bg_deep"], ph)

