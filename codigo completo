    def _fazer_cadastro_atendente(self):
        """
        Valida e salva o novo atendente no DB.
        Após sucesso, loga automaticamente no dashboard.
        """
        # Placeholders que devem ser ignorados na validação
        PH = {"Ex: Recepção, Especialidades…", "Ex: Manhã, Tarde, Noite…",
              "atendente@saudevip.com", "(99) 99999-9999"}

        def g(e):
            v = e.get().strip()
            return "" if v in PH else v

        nome  = g(self._cad_a_nome)
        setor = g(self._cad_a_setor)
        turno = g(self._cad_a_turno)
        email = g(self._cad_a_email)
        tel   = g(self._cad_a_tel)
        login = g(self._cad_a_login)
        senha = self._cad_a_senha.get()
        conf  = self._cad_a_conf.get()

        # Validações básicas
        if not all([nome, setor, email, tel, login, senha, conf]):
            self._lbl_status_cad_a.config(text="Preencha todos os campos obrigatórios.", fg=C["danger"])
            return
        if len(senha) < 6:
            self._lbl_status_cad_a.config(text="Senha deve ter ao menos 6 caracteres.", fg=C["danger"])
            return
        if senha != conf:
            self._lbl_status_cad_a.config(text="As senhas não coincidem.", fg=C["danger"])
            return
        if login in DB["usuarios"]:
            self._lbl_status_cad_a.config(text=f"Usuário '{login}' já existe.", fg=C["danger"])
            return

        # Salva no banco em memória
        DB["usuarios"][login] = {
            "hash": hashlib.sha256(senha.encode()).hexdigest(),
            "tipo": "atendente",
            "nome": nome,
            "setor": setor,
            "turno": turno or "Não informado",
            "email": email,
            "telefone": tel,
        }
        self._lbl_status_cad_a.config(text=f"Conta criada! Bem-vindo(a), {nome.split()[0]}!", fg=C["success"])
        self.root.after(1000, lambda: self._mostrar_dashboard_atendente(login))

