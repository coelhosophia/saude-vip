    def _fazer_login(self):
        """Valida credenciais consultando o banco SQLite."""
        u = self._e_usuario.get().strip()
        s = self._e_senha.get()
        if not u or not s:
            self._lbl_status_login.config(text="Preencha todos os campos.")
            return
        h = hashlib.sha256(s.encode()).hexdigest()
        usuario = db_buscar_usuario(u)
        if usuario and usuario["hash_senha"] == h:
            self._lbl_status_login.config(text="Autenticando…", fg=C["success"])
            if usuario["tipo"] == "medico":
                self.root.after(350, lambda: self._mostrar_dashboard_medico(u))
            else:
                self.root.after(350, lambda: self._mostrar_dashboard_atendente(u))
        else:
            self._lbl_status_login.config(text="Usuário ou senha incorretos.", fg=C["danger"])
            self._e_senha.delete(0, tk.END)

