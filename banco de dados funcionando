def _conn():
    """Abre conexão com o banco; ativa chaves estrangeiras."""
    con = sqlite3.connect(DB_PATH)
    con.execute("PRAGMA foreign_keys = ON")
    con.row_factory = sqlite3.Row   # permite acessar colunas por nome
    return con


def inicializar_banco():
    """
    Cria todas as tabelas se ainda não existirem e
    insere dados iniciais de exemplo na primeira execução.
    """
    with _conn() as con:
        # ── Tabela de usuários (médicos e atendentes) ──────────
        con.execute("""
            CREATE TABLE IF NOT EXISTS usuarios (
                login       TEXT PRIMARY KEY,
                hash_senha  TEXT NOT NULL,
                tipo        TEXT NOT NULL CHECK(tipo IN ('medico','atendente')),
                nome        TEXT NOT NULL,
                email       TEXT,
                telefone    TEXT,
                -- campos exclusivos de médico
                crm             TEXT,
                especialidade   TEXT,
                -- campos exclusivos de atendente
                setor   TEXT,
                turno   TEXT
            )
        """)

        # ── Tabela de pacientes ────────────────────────────────
        con.execute("""
            CREATE TABLE IF NOT EXISTS pacientes (
                id              TEXT PRIMARY KEY,
                nome            TEXT NOT NULL,
                cpf             TEXT,
                nascimento      TEXT,
                email           TEXT,
                telefone        TEXT,
                plano           TEXT DEFAULT 'Particular',
                tipo_sanguineo  TEXT DEFAULT '?',
                alergias        TEXT DEFAULT 'Nenhuma',
                medico_resp     TEXT
            )
        """)

        # ── Tabela de consultas agendadas ──────────────────────
        con.execute("""
            CREATE TABLE IF NOT EXISTS consultas (
                id       INTEGER PRIMARY KEY AUTOINCREMENT,
                data     TEXT NOT NULL,
                hora     TEXT NOT NULL,
                paciente TEXT NOT NULL,
                medico   TEXT NOT NULL,
                status   TEXT DEFAULT 'Aguardando',
                tipo     TEXT DEFAULT 'Consulta',
                convenio TEXT DEFAULT 'Particular'
            )
        """)

        # ── Tabela da fila de espera ───────────────────────────
        con.execute("""
            CREATE TABLE IF NOT EXISTS fila (
                id      INTEGER PRIMARY KEY AUTOINCREMENT,
                senha   TEXT NOT NULL,
                nome    TEXT NOT NULL,
                tipo    TEXT DEFAULT 'Consulta',
                medico  TEXT DEFAULT '—',
                chegada TEXT NOT NULL,
                status  TEXT DEFAULT 'Aguardando'
            )
        """)

        # ── Tabela de prontuários ──────────────────────────────
        con.execute("""
            CREATE TABLE IF NOT EXISTS prontuarios (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                paciente_id TEXT NOT NULL,
                data        TEXT NOT NULL,
                medico      TEXT NOT NULL,
                tipo        TEXT DEFAULT 'Consulta',
                diagnostico TEXT,
                prescricao  TEXT DEFAULT '—',
                retorno     TEXT DEFAULT '—',
                FOREIGN KEY (paciente_id) REFERENCES pacientes(id)
            )
        """)

        # ── Insere dados de exemplo apenas se tabelas vazias ──
        if not con.execute("SELECT 1 FROM usuarios LIMIT 1").fetchone():
            _inserir_dados_exemplo(con)


