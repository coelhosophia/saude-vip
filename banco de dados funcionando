    def _at_navegar(self, p):
        if self._at_pagina in self._at_frames:
            self._at_frames[self._at_pagina].pack_forget()
        for k, b in self._at_nav_btns.items():
            b.config(bg=C["bg_card"] if k == p else C["bg_panel"],
                     fg=C["accent2"] if k == p else C["text_mid"])
        self._at_pagina = p
        self._at_frames[p].pack(fill=tk.BOTH, expand=True)

