# ── Funções de acesso: Usuários ────────────────────────────────

def db_buscar_usuario(login):
    """Retorna dict-like Row do usuário ou None."""
    with _conn() as con:
        return con.execute("SELECT * FROM usuarios WHERE login=?", (login,)).fetchone()


def db_salvar_usuario(login, hash_senha, tipo, nome, email, telefone,
                      crm=None, especialidade=None, setor=None, turno=None):
    """Insere novo usuário no banco."""
    with _conn() as con:
        con.execute(
            "INSERT INTO usuarios VALUES (?,?,?,?,?,?,?,?,?,?)",
            (login, hash_senha, tipo, nome, email, telefone, crm, especialidade, setor, turno)
        )


# ── Funções de acesso: Pacientes ───────────────────────────────

def db_listar_pacientes():
    """Retorna lista de todos os pacientes."""
    with _conn() as con:
        return con.execute("SELECT * FROM pacientes ORDER BY nome").fetchall()


def db_buscar_paciente(pid):
    with _conn() as con:
        return con.execute("SELECT * FROM pacientes WHERE id=?", (pid,)).fetchone()


def db_salvar_paciente(nome, cpf, nascimento, email, telefone,
                       plano, tipo_sanguineo, alergias, medico_resp):
    """Gera ID sequencial e insere paciente."""
    with _conn() as con:
        count = con.execute("SELECT COUNT(*) FROM pacientes").fetchone()[0]
        novo_id = f"p{count + 1:03d}"
        # Garante ID único mesmo com exclusões
        while con.execute("SELECT 1 FROM pacientes WHERE id=?", (novo_id,)).fetchone():
            count += 1
            novo_id = f"p{count + 1:03d}"
        con.execute(
            "INSERT INTO pacientes VALUES (?,?,?,?,?,?,?,?,?,?)",
            (novo_id, nome, cpf, nascimento, email, telefone,
             plano, tipo_sanguineo, alergias, medico_resp)
        )
        return novo_id


