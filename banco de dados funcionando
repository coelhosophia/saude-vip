# ── Funções de acesso: Fila ────────────────────────────────────

def db_listar_fila():
    with _conn() as con:
        return con.execute(
            "SELECT * FROM fila ORDER BY id"
        ).fetchall()


def db_proximo_numero_fila():
    """Retorna o próximo número de senha baseado no maior existente."""
    with _conn() as con:
        row = con.execute("SELECT MAX(CAST(SUBSTR(senha,2) AS INTEGER)) FROM fila").fetchone()
        ultimo = row[0] or 0
        return ultimo + 1


def db_adicionar_fila(senha, nome, tipo, medico, chegada):
    with _conn() as con:
        con.execute(
            "INSERT INTO fila (senha,nome,tipo,medico,chegada,status) VALUES (?,?,?,?,?,?)",
            (senha, nome, tipo, medico, chegada, "Aguardando")
        )


def db_atualizar_status_fila(fid, novo_status):
    with _conn() as con:
        con.execute("UPDATE fila SET status=? WHERE id=?", (novo_status, fid))


def db_remover_fila(fid):
    with _conn() as con:
        con.execute("DELETE FROM fila WHERE id=?", (fid,))


# ── Funções de acesso: Prontuários ─────────────────────────────

def db_listar_prontuarios(paciente_id):
    with _conn() as con:
        return con.execute(
            "SELECT * FROM prontuarios WHERE paciente_id=? ORDER BY data DESC",
            (paciente_id,)
        ).fetchall()


def db_todos_prontuarios():
    """Retorna todos os prontuários com nome do paciente."""
    with _conn() as con:
        return con.execute("""
            SELECT pr.*, pa.nome AS nome_paciente
            FROM prontuarios pr
            JOIN pacientes pa ON pr.paciente_id = pa.id
            ORDER BY pr.data DESC
        """).fetchall()


def db_salvar_prontuario(paciente_id, data, medico, tipo, diagnostico, prescricao, retorno):
    with _conn() as con:
        con.execute(
            "INSERT INTO prontuarios (paciente_id,data,medico,tipo,diagnostico,prescricao,retorno) VALUES (?,?,?,?,?,?,?)",
            (paciente_id, data, medico, tipo, diagnostico, prescricao, retorno)
        )


