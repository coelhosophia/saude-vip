        form = tk.Frame(win, bg=C["bg_deep"])
        form.pack(padx=36, fill=tk.X)
        ents = {}
        for cam, ph in [("Paciente", "Nome do paciente"), ("Data", "DD/MM/AAAA"),
                        ("Hora", "HH:MM"), ("Tipo", "Consulta / Retorno / Exame")]:
            rotulo(form, cam.upper(), C["bg_deep"], top=10)
            ents[cam] = campo(form, C["bg_deep"], ph)

        def salvar():
            pac = ents["Paciente"].get().strip()
            if not pac:
                messagebox.showwarning("Atenção", "Informe o paciente.", parent=win)
                return
            u = db_buscar_usuario(self._med_login)
            # Persiste no banco SQLite
            db_salvar_consulta(
                data=ents["Data"].get().strip(),
                hora=ents["Hora"].get().strip(),
                paciente=pac, medico=u["nome"],
                status="Aguardando",
